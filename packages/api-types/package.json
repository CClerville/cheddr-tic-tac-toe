    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cheddr/config-eslint": "workspace:*",
    "@cheddr/config-ts": "workspace:*",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
