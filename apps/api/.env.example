# --- Runtime --------------------------------------------------------------
NODE_ENV=development
PORT=3005

# Comma-separated list of allowed CORS origins. Use "*" only for local dev.
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006

# --- Postgres (Neon) ------------------------------------------------------
# In Vercel, this is provisioned automatically by the Neon Marketplace
# integration. Locally, point this at any Neon branch (or a local Postgres).
DATABASE_URL=postgres://user:password@host/db?sslmode=require

# --- Redis (Upstash) ------------------------------------------------------
# Provisioned automatically in Vercel via the Upstash Marketplace integration,
# which injects KV_REST_API_URL / KV_REST_API_TOKEN. The app reads either the
# canonical UPSTASH_REDIS_REST_* names or the KV_REST_API_* aliases.
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxx
# KV_REST_API_URL=https://xxxx.upstash.io
# KV_REST_API_TOKEN=xxxx

# --- Auth (Clerk) ---------------------------------------------------------
CLERK_SECRET_KEY=sk_test_xxx
CLERK_PUBLISHABLE_KEY=pk_test_xxx

# --- Anonymous JWT --------------------------------------------------------
# 32+ char secret used to sign anonymous device JWTs. Generate with:
#   openssl rand -hex 32
JWT_SECRET=replace-me-with-a-32-plus-char-random-string

# --- Observability --------------------------------------------------------
SENTRY_DSN=
