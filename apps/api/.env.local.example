# Copy to `apps/api/.env.local` for local API runs.
# Full template: see `apps/api/.env.example`.

# Vercel AI Gateway (commentary / hints / analysis)
# Omit AI_GATEWAY_API_KEY to use VERCEL_OIDC_TOKEN from `vercel env pull`.
# A stale key wins over OIDC and causes 401 until you fix or remove it.
# AI_GATEWAY_API_KEY=
# AI_MODEL=openai/gpt-4o-mini
# Stronger default for streaming `/ai/commentary` only (spatial accuracy).
# AI_MODEL_COMMENTARY=openai/gpt-4.1-mini
