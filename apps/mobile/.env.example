# Mobile app environment. Anything starting with EXPO_PUBLIC_ is bundled
# into the JS at build time, so do NOT put secrets here.

# Base URL of the deployed Hono API (Vercel). For local dev with the API
# running on the same machine, use http://<your-lan-ip>:3005 so the
# device/simulator can reach it. EAS builds pull this from `eas.json` env
# blocks (or `eas env:create`), so this file only matters for `expo start`.
EXPO_PUBLIC_API_URL=https://cheddr-tic-tac-toe-api.vercel.app

# Clerk publishable key (safe to expose).
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# Sentry DSN for the mobile app (optional).
EXPO_PUBLIC_SENTRY_DSN=
