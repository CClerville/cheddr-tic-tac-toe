{
  "expo": {
    "name": "Cheddr Tic-Tac-Toe",
    "slug": "cheddr-tic-tac-toe",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "cheddr",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.cheddr.tictactoe",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#18181b"
      },
      "package": "com.cheddr.tictactoe"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2c7590f1-9e24-44d9-9e90-0b4846d9f8e4"
      }
    },
    "owner": "cclerv",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/2c7590f1-9e24-44d9-9e90-0b4846d9f8e4"
    }
  }
}
